# SPA fallback for Apache: serve index.html for client routes (/login, etc.).
# Requires: mod_rewrite, AllowOverride FileInfo or All for this directory.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
