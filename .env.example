# Tarteel Platform - Environment Variables Example
# Copy to .env.local for local development.
#
# BUILD TIME (Vite): VITE_* is baked into the bundle when you run `npm run build`.
# Load order (later wins): .env -> .env.production -> .env.local -> .env.production.local
# So .env.local OVERRIDES .env.production. For production builds, either remove VITE_API_URL
# from .env.local or set it to https://back.rattelapp.com/api before building.
#
# API Configuration
# VITE_API_URL=https://back.rattelapp.com/api
VITE_API_URL=http://localhost:8002/api

# Set true on Apache without SPA rewrite (URLs become site.com/#/login). See .env.production.
# VITE_USE_HASH_ROUTER=true
VITE_TOKEN_EXPIRY=24

# App Configuration  
VITE_APP_NAME=Tarteel Platform
VITE_DEFAULT_LANGUAGE=ar
VITE_SUPPORTED_LANGUAGES=ar,en

# UI Configuration
VITE_ITEMS_PER_PAGE=20
VITE_MAX_FILE_SIZE_MB=10

# Development Settings
VITE_DEV_MODE=true
VITE_DEBUG=true
VITE_SHOW_API_ERRORS=true
