# 🚀 Frontend Environment Variables - Sheky Platform

# =====================================================
# 🌐 API Configuration
# =====================================================
# Main API base URL - Backend server endpoint
# Local development: http://localhost:3001/api
# Production: https://your-backend-domain.com/api
# VITE_API_URL=http://localhost:3001/api
VITE_API_URL=https://shike.developteam.site/api

# =====================================================
# 🔒 Authentication & Security
# =====================================================
# JWT token expiration time (in hours)
VITE_TOKEN_EXPIRY=24

# API timeout (in milliseconds)
VITE_API_TIMEOUT=30000

# =====================================================
# 🎨 Application Configuration
# =====================================================
# Application name
VITE_APP_NAME=Sheky Platform

# Application version
VITE_APP_VERSION=1.0.0

# Default language
VITE_DEFAULT_LANGUAGE=ar

# Supported languages (comma-separated)
VITE_SUPPORTED_LANGUAGES=ar,en

# =====================================================
# 📱 UI Configuration
# =====================================================
# Items per page for pagination
VITE_ITEMS_PER_PAGE=20

# Max file size for uploads (in MB)
VITE_MAX_FILE_SIZE_MB=10

# Supported image formats
VITE_SUPPORTED_IMAGE_FORMATS=jpg,jpeg,png,gif,webp

# Supported video formats  
VITE_SUPPORTED_VIDEO_FORMATS=mp4,webm,mov,avi

# =====================================================
# 🔧 Development Configuration
# =====================================================
# Enable development mode
VITE_DEV_MODE=true

# Enable debug logs
VITE_DEBUG=true

# Show API errors in UI (development only)
VITE_SHOW_API_ERRORS=true

# =====================================================
# 📊 Analytics & Monitoring
# =====================================================
# Google Analytics ID (optional)
# VITE_GA_ID=GA-XXXXXXXXX

# Sentry DSN for error tracking (optional)
# VITE_SENTRY_DSN=https://your-sentry-dsn

# =====================================================
# 🌍 External Services (Optional)
# =====================================================
# Payment gateway API URL (optional)
# VITE_PAYMENT_API_URL=https://payment-api.example.com

# File storage service URL (optional)
# VITE_STORAGE_URL=https://storage.example.com

# Notification service URL (optional)
# VITE_NOTIFICATION_URL=https://notifications.example.com

# =====================================================
# 📧 Email & Communication (Optional)
# =====================================================
# Support email
VITE_SUPPORT_EMAIL=support@sheky.com

# Contact phone
VITE_CONTACT_PHONE=+966123456789

# =====================================================
# 🏢 Organization Info
# =====================================================
# Company/Organization name
VITE_ORGANIZATION_NAME=Sheky Educational Platform

# Organization website
VITE_ORGANIZATION_WEBSITE=https://sheky.com

# Organization address
VITE_ORGANIZATION_ADDRESS=المملكة العربية السعودية